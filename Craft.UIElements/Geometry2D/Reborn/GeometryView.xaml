<UserControl x:Class="Craft.UIElements.Geometry2D.Reborn.GeometryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Craft.UIElements.Geometry2D.Reborn"
             xmlns:reborn="clr-namespace:Craft.ViewModels.Geometry2D.Reborn;assembly=Craft.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance reborn:GeometryViewModel }">
    <local:GeometryCanvas ClipToBounds="True"
                          x:Name="GeometryCanvas"
                          Items="{Binding Lines}"
                          ViewState="{Binding ViewState, Mode=OneWayToSource}"
                          WorldWindow="{Binding WorldWindow, Mode=TwoWay}"
                          WorldWindowExpanded="{Binding WorldWindowExpanded, Mode=TwoWay}"
                          RequestedWorldWindow="{Binding RequestedWorldWindow, Mode=TwoWay}"
                          RequestedWorldFocus="{Binding RequestedWorldFocus, Mode=TwoWay}"
                          WorldWindowBounds="{Binding WorldWindowBounds, Mode=TwoWay}"
                          CursorWorldPosition="{Binding CursorWorldPosition, Mode=OneWayToSource}"
                          LockAspectRatio="{Binding LockAspectRatio}"
                          LockXAxis="{Binding LockXAxis}"
                          LockYAxis="{Binding LockYAxis}"
                          DampFocusShifts="{Binding DampFocusShifts}"
                          FocusShiftDamping="{Binding FocusShiftDamping}"
                          ShowGrid="{Binding ShowGrid}"
                          ShowCoordinateSystem="{Binding ShowCoordinateSystem}"
                          DebugMode="{Binding DebugMode}">
    </local:GeometryCanvas>
</UserControl>

<Window x:Class="Craft.UIElements.Reborn.GuiTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Craft.UIElements.Reborn.GuiTest"
        xmlns:reborn="clr-namespace:Craft.UIElements.Geometry2D.Reborn;assembly=Craft.UIElements"
        mc:Ignorable="d"
        Title="Craft.UIElements.Reborn.GuiTest" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="DarkSlateGray" BorderThickness="1" Margin="3">
            <reborn:GeometryCanvas ClipToBounds="True"
                                   Items="{Binding Lines}"
                                   ViewState="{Binding ViewState, Mode=OneWayToSource}"
                                   WorldWindow="{Binding WorldWindow, Mode=TwoWay}"
                                   WorldWindowBounds="{Binding WorldWindowBounds, Mode=TwoWay}"
                                   ExpandedWorldWindow="{Binding ExpandedWorldWindow, Mode=TwoWay}"
                                   CursorWorldPosition="{Binding CursorWorldPosition, Mode=OneWayToSource}"
                                   LockAspectRatio="{Binding LockAspectRatio}"
                                   LockXAxis="{Binding LockXAxis}"
                                   DebugMode="{Binding DebugMode}"
                                   DataContext="{Binding GeometryViewModel}"/>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="75"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.CursorWorldPosition.X, StringFormat=N2}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.CursorWorldPosition.Y, StringFormat=N2}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="X scaling:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.ViewState.Scaling.Width, StringFormat=N2}"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Y scaling:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.ViewState.Scaling.Height, StringFormat=N2}"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Lock aspect ratio:" Margin="0, 0, 10, 0"/>
            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding GeometryViewModel.LockAspectRatio}" />
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Lock x axis:" Margin="0, 0, 10, 0"/>
            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding GeometryViewModel.LockXAxis}" />
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Lock y axis:" Margin="0, 0, 10, 0"/>
            <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding GeometryViewModel.LockYAxis}" />
            <TextBlock Grid.Row="7" Grid.Column="0" Text="Debug mode:" Margin="0, 0, 10, 0"/>
            <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding GeometryViewModel.DebugMode}" />
            <GroupBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="DarkSlateGray" BorderThickness="1" Header="World Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="DarkSlateGray" BorderThickness="1" Header="Expanded World Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.ExpandedWorldWindow.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.ExpandedWorldWindow.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.ExpandedWorldWindow.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.ExpandedWorldWindow.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="DarkSlateGray" BorderThickness="1" Header="World Window Bounds">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Craft.UIElements.Reborn.GuiTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Craft.UIElements.Reborn.GuiTest"
        xmlns:reborn="clr-namespace:Craft.UIElements.Geometry2D.Reborn;assembly=Craft.UIElements"
        mc:Ignorable="d"
        Title="Craft.UIElements.Reborn.GuiTest" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="DarkSlateGray" BorderThickness="1" Margin="3">
            <reborn:GeometryCanvas ClipToBounds="True"
                                   Items="{Binding Lines}"
                                   ViewState="{Binding ViewState, Mode=OneWayToSource}"
                                   WorldWindow="{Binding WorldWindow, Mode=TwoWay}"
                                   WorldWindowExpanded="{Binding WorldWindowExpanded, Mode=TwoWay}"
                                   RequestedWorldWindow="{Binding RequestedWorldWindow, Mode=TwoWay}"
                                   RequestedWorldFocus="{Binding RequestedWorldFocus, Mode=TwoWay}"
                                   WorldWindowBounds="{Binding WorldWindowBounds, Mode=TwoWay}"
                                   CursorWorldPosition="{Binding CursorWorldPosition, Mode=OneWayToSource}"
                                   LockAspectRatio="{Binding LockAspectRatio}"
                                   LockXAxis="{Binding LockXAxis}"
                                   LockYAxis="{Binding LockYAxis}"
                                   DampFocusShifts="{Binding DampFocusShifts}"
                                   FocusShiftDamping="{Binding FocusShiftDamping}"
                                   ShowGrid="{Binding ShowGrid}"
                                   ShowCoordinateSystem="{Binding ShowCoordinateSystem}"
                                   DebugMode="{Binding DebugMode}"
                                   DataContext="{Binding GeometryViewModel}"/>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="75"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.CursorWorldPosition.X, StringFormat=N2}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.CursorWorldPosition.Y, StringFormat=N2}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="X scaling:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.ViewState.Scaling.Width, StringFormat=N2}"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Y scaling:" Margin="0, 0, 10, 0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.ViewState.Scaling.Height, StringFormat=N2}"/>
            <GroupBox Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="DarkSlateGray" BorderThickness="1" Header="World Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindow.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="DarkSlateGray" BorderThickness="1" Header="Expanded World Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowExpanded.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowExpanded.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowExpanded.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowExpanded.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                      BorderBrush="DarkSlateGray" BorderThickness="1"
                      Header="World Window Bounds">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MinX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MinY, StringFormat=N2}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MaxX, StringFormat=N2}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GeometryViewModel.WorldWindowBounds.MaxY, StringFormat=N2}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5, 0, 0, 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0"
                      BorderBrush="DarkSlateGray" BorderThickness="1"
                      Header="Place World Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X min:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_XMin}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y min:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_XMax}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X max:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_YMin}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y max:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_YMax}"/>
                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" Content="Apply"
                            Width="50" Margin="3, 0, 0, 0"
                            Command="{Binding SetWorldWindowCommand}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="1"
                      BorderBrush="DarkSlateGray" BorderThickness="1"
                      Header="Place World Focus">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_FocusX}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_FocusY}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X ratio:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_FocusRatioX}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y ratio:" Margin="0, 0, 10, 0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="1"
                             Text="{Binding RequestedWW_FocusRatioY}"/>
                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" Content="Apply"
                            Width="50" Margin="3, 0, 0, 0"
                            Command="{Binding SetWorldFocusCommand}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="Focus Shift" 
                      BorderBrush="DarkSlateGray" BorderThickness="1">
                <StackPanel Orientation="Vertical">
                    <CheckBox Content="Damp" IsChecked="{Binding GeometryViewModel.DampFocusShifts}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Damping:" Margin="0, 0, 10, 0"/>
                        <TextBox Grid.Column="1" Text="{Binding FocusShiftDamping}" Width="30" />
                    </Grid>
                </StackPanel>
            </GroupBox>
            <StackPanel Grid.Column="3" Margin="3">
                <CheckBox Content="Lock aspect ratio" IsChecked="{Binding GeometryViewModel.LockAspectRatio}" />
                <CheckBox Content="Lock X axis" IsChecked="{Binding GeometryViewModel.LockXAxis}" />
                <CheckBox Content="Lock Y axis" IsChecked="{Binding GeometryViewModel.LockYAxis}" />
                <CheckBox Content="Show grid" IsChecked="{Binding GeometryViewModel.ShowGrid}" />
                <CheckBox Content="Show coordinate system" IsChecked="{Binding GeometryViewModel.ShowCoordinateSystem}" />
                <CheckBox Content="Debug mode" IsChecked="{Binding GeometryViewModel.DebugMode}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Craft.Simulation.GuiTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Craft.Simulation.GuiTest"
        xmlns:bouncingBall="clr-namespace:Craft.Simulation.GuiTest.BouncingBall"
        xmlns:vanishingBoundaries="clr-namespace:Craft.Simulation.GuiTest.VanishingBoundaries"
        xmlns:pushingBalls="clr-namespace:Craft.Simulation.GuiTest.PushingBalls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Closing="MainWindow_OnClosing">
    <TabControl>
        <TabItem Header="Bouncing Ball">
            <bouncingBall:BouncingBallView DataContext="{Binding BouncingBallViewModel}"/>
        </TabItem>
        <TabItem Header="Vanishing Boundaries">
            <vanishingBoundaries:VanishingBoundariesView DataContext="{Binding VanishingBoundariesViewModel}"/>
        </TabItem>
        <TabItem Header="Pushing Balls">
            <pushingBalls:PushingBallsView DataContext="{Binding PushingBallsViewModel}"/>
        </TabItem>
    </TabControl>
</Window>
